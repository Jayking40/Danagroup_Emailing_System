{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,                // Required for modern imports
    "allowSyntheticDefaultImports": true,   // Required for express-session
    "moduleResolution": "node16",   
    "module": "node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2021",
    "sourceMap": true,
    "rootDir": "./",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@config/*": ["src/config/*"],
      "@common/*": ["src/common/*"],
      "@jobs/*": ["src/jobs/*"]
    }
  },
  "include": ["src/**/*"]
}
