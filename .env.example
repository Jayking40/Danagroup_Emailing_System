# ─────────────────────────────────────────────────────────────────────────────
# DIMS — Dana Internal Mail & Intranet System
# Root Environment Variables Example
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
APP_URL=https://dims.danagroup.internal

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dims_db
DB_USER=dims_user
DB_PASSWORD=password
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── MinIO Object Storage ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=Danagroup
MINIO_SECRET_KEY=c86715c3879e65646bad47042ccf5ea54fd3d5e65beabfaa8b2de69b246486f2
MINIO_BUCKET=dims-attachments

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ES_NODE=http://elasticsearch:9200

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=SxQMjF1QteZ3QRK4utGIrZ3FNutHBOD/JkZImZrqkPo=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── App / CORS ───────────────────────────────────────────────────────────────
# Dev (docker-compose.dev.yml — access via nginx on port 80): http://localhost
# Production (nginx on domain): https://dims.danagroup.internal
# Comma-separate multiple origins if needed: http://localhost,https://dims.danagroup.internal
FRONTEND_URL=http://localhost,*.trycloudflare.com
SESSION_SECRET=replace_with_a_long_random_string_minimum_32_chars

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Cloudflare Tunnel (optional — only needed for named tunnel) ────────────
# Get token: cloudflared tunnel create dims-dev  →  paste output below
# Required only if using the named tunnel in docker-compose.tunnel.yml
CLOUDFLARE_TUNNEL_TOKEN=
